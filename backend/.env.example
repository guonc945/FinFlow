# FinFlow backend environment template
# Copy this file to backend/.env on the target server, then fill in real values.

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Option A: set DATABASE_URL directly and leave the DB_* fields as-is.
# Option B: leave DATABASE_URL empty and configure the DB_* fields below.
DATABASE_URL=

# Supported values in current code: mssql, sqlserver, sql_server, sqlite, postgresql
DB_DIALECT=mssql
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_HOST=localhost
DB_PORT=1433
DB_NAME=finflow
DB_USER=admin
DB_PASSWORD=change_me
DB_ENCRYPT=yes
DB_TRUST_SERVER_CERT=yes
DB_TIMEOUT=30

# Legacy / manager-side compatibility fields.
# The current backend runtime does not require these two fields directly,
# but the manager and deployment flow may still read them.
DB_CONFIG_FILE=../database.txt
DB_USE_CONFIG_FILE=true

# -----------------------------------------------------------------------------
# Auth / encryption
# -----------------------------------------------------------------------------
SECRET_KEY=change_me_to_a_long_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Option A: put the raw encryption key here.
ENCRYPTION_KEY=
# Option B: point to an encryption key file.
ENCRYPTION_KEY_FILE=.encryption.key

# -----------------------------------------------------------------------------
# App runtime
# -----------------------------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8100
APP_RELOAD=false
ALLOWED_ORIGINS=http://localhost:5273,http://localhost:3000
ALLOW_LAN_ORIGINS=false

# -----------------------------------------------------------------------------
# Marki integration
# Required only if you use Marki data sync.
# -----------------------------------------------------------------------------
MARKI_USER=
MARKI_PASSWORD=
MARKI_SYSTEM_ID=
MARKI_COOKIE=

# Optional Marki tuning
MARKI_RESIDENT_PAGE_SIZE=500
MARKI_PARK_PAGE_SIZE=500
MARKI_HOUSE_PAGE_SIZE=500
MARKI_PREPAYMENT_RECORD_API_ID=31
MARKI_PREPAYMENT_RECORD_PAGE_SIZE=1000
MARKI_DEPOSIT_RECORD_API_ID=30
MARKI_DEPOSIT_RECORD_PAGE_SIZE=1000
MARKI_RECEIPT_BILL_API_ID=29

# -----------------------------------------------------------------------------
# Kingdee integration
# Required only if you use Kingdee OAuth / voucher push.
# -----------------------------------------------------------------------------
KINGDEE_APP_ID=
KINGDEE_APP_SECRET=
KINGDEE_AUTH_URL=https://api.kingdee.com/jdy/oauth2/token

# -----------------------------------------------------------------------------
# Diagnostics
# -----------------------------------------------------------------------------
ENABLE_RECEIPT_DRILLDOWN_PERF_LOG=false

# -----------------------------------------------------------------------------
# One-off migration helpers
# Used only by migration scripts, not by normal API startup.
# -----------------------------------------------------------------------------
SOURCE_DB_HOST=
SOURCE_DB_PORT=5432
SOURCE_DB_NAME=
SOURCE_DB_USER=
SOURCE_DB_PASSWORD=
