# FinFlow backend environment template
# Copy this file to backend/.env on the target server, then fill in real values.
# Never commit the real backend/.env or any live secrets to version control.

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Option A: set DATABASE_URL directly and leave the DB_* fields as-is.
# Option B: leave DATABASE_URL empty and configure the DB_* fields below.
DATABASE_URL=

# Supported values in current code: mssql, sqlserver, sql_server, sqlite, postgresql
DB_DIALECT=mssql
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_HOST=localhost
DB_PORT=1433
DB_NAME=finflow
DB_USER=admin
DB_PASSWORD=change_me
DB_ENCRYPT=yes
DB_TRUST_SERVER_CERT=yes
DB_TIMEOUT=30
FINFLOW_ENABLE_STARTUP_BOOTSTRAP=false

# Legacy / manager-side compatibility fields.
# The current backend runtime does not require these two fields directly,
# but the manager and deployment flow may still read them.
DB_CONFIG_FILE=../database.txt
DB_USE_CONFIG_FILE=true

# -----------------------------------------------------------------------------
# Auth / encryption
# -----------------------------------------------------------------------------
SECRET_KEY=change_me_to_a_long_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Option A: put the raw encryption key here.
ENCRYPTION_KEY=
# Option B: point to an encryption key file.
ENCRYPTION_KEY_FILE=.encryption.key

# -----------------------------------------------------------------------------
# App runtime
# -----------------------------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8100
APP_RELOAD=false
# Production deployments should use HTTPS origins only.
ALLOWED_ORIGINS=http://localhost:5273,http://127.0.0.1:5273,http://localhost:3000,http://127.0.0.1:3000
ALLOW_LAN_ORIGINS=false

# -----------------------------------------------------------------------------
# Marki integration
# Required only if you use Marki data sync.
# -----------------------------------------------------------------------------
MARKI_USER=
MARKI_PASSWORD=
MARKI_SYSTEM_ID=
MARKI_COOKIE=
KINGDEE_VOUCHER_PUSH_API_ID=1
KINGDEE_ACCOUNTING_SUBJECT_API_ID=2
KINGDEE_CUSTOMER_API_ID=3
KINGDEE_SUPPLIER_API_ID=4
KINGDEE_HOUSE_API_ID=5
KINGDEE_AUXILIARY_DATA_API_ID=6
KINGDEE_AUXILIARY_DATA_CATEGORY_API_ID=7
KINGDEE_ACCOUNT_BOOK_API_ID=8
KINGDEE_BANK_ACCOUNT_API_ID=9
KINGDEE_VOUCHER_QUERY_API_ID=28
KINGDEE_TAX_RATE_API_ID=32
MARKI_PROJECT_API_ID=22
MARKI_RESIDENT_API_ID=23
MARKI_HOUSE_API_ID=24
MARKI_PARK_API_ID=25
MARKI_CHARGE_ITEM_API_ID=26
MARKI_BILL_API_ID=27

# Optional Marki tuning
MARKI_RESIDENT_PAGE_SIZE=500
MARKI_PARK_PAGE_SIZE=500
MARKI_HOUSE_PAGE_SIZE=500
MARKI_PREPAYMENT_RECORD_API_ID=31
MARKI_PREPAYMENT_RECORD_PAGE_SIZE=1000
MARKI_DEPOSIT_RECORD_API_ID=30
MARKI_DEPOSIT_RECORD_PAGE_SIZE=1000
MARKI_RECEIPT_BILL_API_ID=29

# Bill sync strategy (incremental + periodic full backfill)
MARKI_BILL_FORCE_FULL_SYNC=false
MARKI_BILL_FULL_SYNC_INTERVAL_HOURS=168
MARKI_BILL_INCREMENTAL_OVERLAP=200
# When incremental page 1 is empty, allow one automatic FULL retry per community
# within this cooldown window to recover hand-added / late-visible bills.
MARKI_BILL_EMPTY_INCREMENTAL_FULL_SYNC_COOLDOWN_HOURS=24
# During true FULL reconciliation, bills missing from Marki are soft-deleted only
# after they have not been seen for this many hours.
MARKI_BILL_MISSING_GRACE_HOURS=168
# Optional month upper bound (e.g. 2027-12). Leave empty to avoid truncation.
MARKI_BILL_END_MONTH=

# Receipt bill sync strategy (incremental + periodic full backfill)
MARKI_RECEIPT_BILL_FORCE_FULL_SYNC=false
MARKI_RECEIPT_BILL_FULL_SYNC_INTERVAL_HOURS=168
MARKI_RECEIPT_BILL_INCREMENTAL_OVERLAP_SECONDS=600

# -----------------------------------------------------------------------------
# Kingdee integration
# Required only if you use Kingdee OAuth / voucher push.
# -----------------------------------------------------------------------------
KINGDEE_APP_ID=
KINGDEE_APP_SECRET=
KINGDEE_AUTH_URL=https://api.kingdee.com/jdy/oauth2/token

# -----------------------------------------------------------------------------
# Diagnostics
# -----------------------------------------------------------------------------
ENABLE_RECEIPT_DRILLDOWN_PERF_LOG=false

# -----------------------------------------------------------------------------
# One-off migration helpers
# Used only by migration scripts, not by normal API startup.
# -----------------------------------------------------------------------------
SOURCE_DB_HOST=
SOURCE_DB_PORT=5432
SOURCE_DB_NAME=
SOURCE_DB_USER=
SOURCE_DB_PASSWORD=
